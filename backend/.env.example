# 服务器配置
PORT=3001
NODE_ENV=development
CORS_ORIGIN=*

# MongoDB数据库
MONGODB_URI=mongodb://localhost:27017/travel_guide

# AI服务配置（三选一或全部配置）
# 通义千问（阿里云）
TONGYI_API_KEY=your_tongyi_api_key_here

# 文心一言（百度）
WENXIN_API_KEY=your_wenxin_api_key_here
WENXIN_CLIENT_ID=your_wenxin_client_id_here
WENXIN_CLIENT_SECRET=your_wenxin_client_secret_here

# OpenAI GPT-4
OPENAI_API_KEY=your_openai_api_key_here
AI_PROVIDER=tongyi  # 可选: tongyi, wenxin, openai

# Firebase认证配置
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# Firebase Admin SDK（用于服务端）
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# JWT密钥（用于自定义token）
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 高德地图API（可选）
AMAP_API_KEY=your_amap_api_key_here